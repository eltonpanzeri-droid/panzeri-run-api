DATABASE_URL="postgresql://panzeri:panzeri@localhost:5432/panzeri_run?schema=public"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
API_PORT=3333
NEXT_PUBLIC_API_URL="http://localhost:3333"
EXPO_PUBLIC_API_URL="http://localhost:3333"

APP_PUBLIC_URL="https://sua-api.exemplo.com"

ASAAS_API_KEY="chave de API do Asaas"
ASAAS_SANDBOX="true"
ASAAS_WEBHOOK_TOKEN="token de autenticacao configurado no webhook do Asaas"

TELEGRAM_BOT_TOKEN="token do bot gerado pelo BotFather"
TELEGRAM_CHAT_ID="id do chat que recebe os avisos"

ANTHROPIC_API_KEY="chave de API da Anthropic (console.anthropic.com) - usada pelo agente de prescricao de treinos. Sem essa variavel, o app usa o motor deterministico normalmente."

RESEND_API_KEY="chave de API do Resend (resend.com) - usada para enviar e-mails automaticos e mensagens do treinador. Sem essa variavel, o envio de e-mail fica desativado."
RESEND_FROM_EMAIL="Panzeri Run <avisos@seudominio.com>"

BACKUP_EMAIL_TO="email para onde o backup diario do banco de dados sera enviado. Sem essa variavel, o backup automatico fica desativado."
